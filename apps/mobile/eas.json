{
  "cli": {
    "version": ">= 18.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "cache": {
        "key": "v1",
        "paths": ["apps/mobile/node_modules"]
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "resourceClass": "medium"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "resourceClass": "medium"
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "resourceClass": "medium"
    }
  },
  "submit": {
    "production": {}
  }
}
