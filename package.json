{
  "name": "pravah",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck:fast": "tsgo -b --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "mcp": "bun run mcp-server.ts",
    "mobile:env": "bun scripts/sync-mobile-env.mjs",
    "mobile:start": "bun run mobile:env && bun run --cwd apps/mobile start",
    "mobile:android": "bun run mobile:env && bun scripts/run-mobile-android.mjs",
    "mobile:android:dev": "bun run mobile:env && bun run --cwd apps/mobile start -- --dev-client",
    "mobile:ios": "bun run mobile:env && bun run --cwd apps/mobile ios",
    "mobile:web": "bun run mobile:env && bun run --cwd apps/mobile web"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.11.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "@tailwindcss/vite": "^4.2.2",
    "better-auth": "1.5.3",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.2"
  }
}
